<idea-plugin>
    <id>com.duckdb.gram</id>
    <name>DuckDB Grammar Support</name>
    <version>1.0.0</version>
    <vendor>DuckDB</vendor>

    <description><![CDATA[
        Provides IDE support for DuckDB PEG grammar files (.gram):
        <ul>
            <li>Syntax highlighting</li>
            <li>Go to Definition and Find Usages for grammar rules</li>
            <li>Navigation between grammar rules and their C++ transformer implementations</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.cidr.lang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- File type -->
        <fileType
            name="DuckDB Grammar"
            language="DuckDBGrammar"
            implementationClass="com.duckdb.gram.GramFileType"
            extensions="gram"
            fieldName="INSTANCE"/>

        <!-- Parser -->
        <lang.parserDefinition
            language="DuckDBGrammar"
            implementationClass="com.duckdb.gram.parser.GramParserDefinition"/>

        <!-- Syntax highlighting -->
        <lang.syntaxHighlighterFactory
            language="DuckDBGrammar"
            implementationClass="com.duckdb.gram.highlighting.GramSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="com.duckdb.gram.highlighting.GramColorSettingsPage"/>

        <!-- Go to Definition / Find Usages -->
        <psi.referenceContributor
            language="DuckDBGrammar"
            implementation="com.duckdb.gram.reference.GramReferenceContributor"/>

        <fileBasedIndex
            implementation="com.duckdb.gram.index.GramRuleNameIndex"/>

        <lang.findUsagesProvider
            language="DuckDBGrammar"
            implementationClass="com.duckdb.gram.usage.GramFindUsagesProvider"/>

        <!-- Grammar → Transformer gutter icon -->
        <codeInsight.lineMarkerProvider
            language="DuckDBGrammar"
            implementationClass="com.duckdb.gram.navigation.GramGutterIconProvider"/>

        <!-- Transformer → Grammar gutter icon (CLion uses ObjectiveC language ID for C/C++) -->
        <codeInsight.lineMarkerProvider
            language="ObjectiveC"
            implementationClass="com.duckdb.gram.navigation.CppTransformerGutterIconProvider"/>

    </extensions>
</idea-plugin>
